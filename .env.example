# Nome do banco que o PostgreSQL vai criar.
POSTGRES_DB=dashboard_escolar
# Usuario administrador do banco.
POSTGRES_USER=postgres
# Senha do banco; troque antes de usar em deploy real.
POSTGRES_PASSWORD=troque-essa-senha

# Porta exposta na sua maquina local ou no host.
APP_PORT=8081
# Porta interna em que o Spring Boot vai rodar.
SERVER_PORT=8081

# Estrategia do Hibernate para criar/atualizar tabelas.
SPRING_JPA_HIBERNATE_DDL_AUTO=update
# Desliga logs SQL por padrao no container.
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_FORMAT_SQL=false
